---
import type { BenefitGridSection } from "./schema"

const { section } = Astro.props as { section: BenefitGridSection }
const gridClass = section.presentation === "value-proposition"
  ? "md:grid-cols-3"
  : "md:grid-cols-2"
---

<div class="mx-auto max-w-6xl">
  <h2 class="max-w-4xl font-display text-3xl leading-tight sm:text-4xl">{section.heading}</h2>
  <ul class:list={["mt-8 grid grid-cols-1 gap-4", gridClass]}>
    {section.items.map((item) => (
      <li>
        <article class="surface-card h-full rounded-3xl p-6">
          <h3 class="text-xl font-bold leading-snug">{item.title}</h3>
          <p class="mt-3 leading-7">{item.body}</p>
        </article>
      </li>
    ))}
  </ul>
</div>
