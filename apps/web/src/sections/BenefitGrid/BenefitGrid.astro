---
import type { BenefitGridSection } from "./schema"

const { section } = Astro.props as { section: BenefitGridSection }
const isPromise = section.presentation === "value-proposition"
const isPrinciples = section.presentation === "principles"
---

{isPromise ? (
  <div class="mx-auto max-w-xl border-x-8 border-magic-lilac bg-magic-cream px-6 py-10 text-center shadow-lg sm:px-10">
    <h2 class="font-display text-3xl leading-none sm:text-4xl">{section.heading}</h2>
    <p class="mt-6 font-mono text-sm leading-6 sm:text-base">{section.items[0].body}</p>
    <ul class="mt-8 space-y-4 text-left text-sm leading-6 sm:text-base">
      {section.items.slice(1).map((item) => <li>{item.body}</li>)}
    </ul>
    <a class="mt-8 inline-block rounded-full border border-magic-orange bg-white px-5 py-3 font-display text-lg text-magic-ink transition-colors hover:bg-magic-orange hover:text-black" data-action="primary" data-analytics-key="kolektyw-promise" data-brand-action="true" href="#umawiam-spotkanie">Chcę poznać szczegóły!</a>
  </div>
) : isPrinciples ? (
  <div class="mx-auto max-w-3xl rounded-2xl border-2 border-magic-purple bg-magic-cream p-5 shadow-lg sm:p-8">
    <div class="border-b-2 border-magic-purple pb-4 text-center">
      <h2 class="inline rounded-full bg-magic-pink px-4 py-2 font-display text-2xl text-magic-ink sm:text-3xl">{section.heading}</h2>
    </div>
    <ul class="mt-6 space-y-5 text-sm leading-6 sm:text-base">
      {section.items.map((item) => <li><strong>{item.title}</strong>{item.body.replace(item.title, "")}</li>)}
    </ul>
  </div>
) : (
  <div class="mx-auto max-w-5xl">
    <h2 class="mx-auto max-w-md rounded-full border-2 border-magic-orange bg-magic-cream px-5 py-2 text-center font-display text-2xl text-magic-ink sm:text-3xl">{section.heading}</h2>
    <ul class="mt-8 grid gap-6 md:grid-cols-2">
      {section.items.map((item) => (
        <li class="flex gap-3 text-sm leading-6 sm:text-base">
          <span aria-hidden="true" class="text-lg">✅</span>
          <p><strong>{item.title}</strong>{" "}{item.body.replace(`${item.title} - `, "")}</p>
        </li>
      ))}
    </ul>
  </div>
)}
