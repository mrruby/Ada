---
import type { OfferSection } from "./schema"

const { section } = Astro.props as { section: OfferSection }
---

<div class="mx-auto max-w-6xl">
  <h2 class="font-display text-3xl leading-tight sm:text-4xl">{section.heading}</h2>
  <ul class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-2">
    {section.offers.map((offer) => (
      <li>
        <article class="surface-card flex h-full flex-col rounded-3xl p-6 sm:p-8">
          <h3 class="text-2xl font-bold leading-snug">{offer.name}</h3>
          {offer.price && (
            <dl class="surface-highlight mt-5 flex items-baseline justify-between gap-4 rounded-2xl p-4">
              <dt class="font-semibold">{offer.price.label}</dt>
              <dd class="font-display text-3xl">{offer.price.value}</dd>
            </dl>
          )}
          <ul class="mt-6 space-y-3 leading-7">
            {offer.features.map((feature) => <li class="flex gap-3"><span aria-hidden="true">✦</span><span>{feature}</span></li>)}
          </ul>
          {offer.cta && (
            <a
              class="mt-8 w-fit rounded-full font-bold"
              data-action="primary"
              data-analytics-key={offer.cta.analyticsKey}
              href={offer.cta.href}
              rel={offer.cta.external ? "noreferrer" : undefined}
              target={offer.cta.external ? "_blank" : undefined}
            >
              {offer.cta.label}
            </a>
          )}
        </article>
      </li>
    ))}
  </ul>
</div>
