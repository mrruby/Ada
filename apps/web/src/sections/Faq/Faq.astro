---
import RichText from "../../page-builder/RichText.astro"
import type { FaqSection } from "./schema"

const { section } = Astro.props as { section: FaqSection }
---

<div class="mx-auto max-w-4xl">
  <h2 class="font-display text-3xl leading-tight sm:text-4xl">{section.heading}</h2>
  <div class="mt-8 space-y-3">
    {section.items.map((item) => (
      <details class="surface-card rounded-2xl p-5 open:shadow-sm">
        <summary class="cursor-pointer pr-8 text-lg font-bold leading-snug">{item.question}</summary>
        <div class="magic-rule mt-4 border-t pt-4">
          <RichText value={item.answer} />
        </div>
      </details>
    ))}
  </div>
</div>
