---
import type { StickyCtaSection } from "./schema"

const { section } = Astro.props as { section: StickyCtaSection }
---

<nav aria-label={section.label} class="surface-strong magic-rule border-b px-4 py-3">
  <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-center gap-3 sm:gap-6">
    <p class="font-semibold">{section.label}</p>
    <a
      class="rounded-full font-bold"
      data-action="primary"
      data-analytics-key={section.targetCta.analyticsKey}
      href={section.targetCta.href}
      rel={section.targetCta.external ? "noreferrer" : undefined}
      target={section.targetCta.external ? "_blank" : undefined}
    >
      {section.targetCta.label}
    </a>
  </div>
</nav>
