---
import RichText from "../../page-builder/RichText.astro"
import type { FinalCtaSection } from "./schema"

const { section } = Astro.props as { section: FinalCtaSection }
---

<footer>
  <h2>{section.heading}</h2>
  <RichText value={section.body} />
  <a
    data-action="primary"
    data-analytics-key={section.primaryCta.analyticsKey}
    href={section.primaryCta.href}
    rel={section.primaryCta.external ? "noreferrer" : undefined}
    target={section.primaryCta.external ? "_blank" : undefined}
  >
    {section.primaryCta.label}
  </a>
  {section.socialLinks && (
    <nav aria-label="Media społecznościowe">
      <ul>{section.socialLinks.map((link) => <li><a href={link.href}>{link.label}</a></li>)}</ul>
    </nav>
  )}
</footer>
