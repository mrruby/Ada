---
import { legacyAssetPath } from "../../lib/legacy-assets"
import type { AudienceSection } from "./schema"

const { section } = Astro.props as { section: AudienceSection }
const isMembership = section.presentation === "membership-dual"
---

{isMembership ? (
  <div class="mx-auto max-w-6xl text-center">
    <h2 class="font-display text-3xl uppercase leading-none sm:text-5xl">{section.heading}</h2>
    <div class="mt-8 grid gap-6 md:grid-cols-2">
      {section.groups.map((group, index) => (
        <div class="flex flex-col items-center">
          <article class:list={[
            "w-full border-2 bg-white p-6 text-left sm:p-8",
            index === 0 ? "border-magic-purple" : "border-magic-pink",
          ]}>
            <h3 class="border-b-2 border-neutral-200 pb-4 text-center text-xl font-extrabold sm:text-2xl">{group.title}</h3>
            <ul class="mt-5 space-y-3 text-sm leading-6 sm:text-base">
              {group.criteria.map((criterion) => <li>{criterion}</li>)}
            </ul>
          </article>
          <a class:list={[
            "mt-4 rounded-full px-5 py-3 text-sm font-extrabold uppercase text-black shadow-md transition-transform hover:-translate-y-0.5",
            index === 0 ? "bg-magic-lilac" : "bg-magic-pink",
          ]} data-action="primary" data-analytics-key={`magic-audience-${index + 1}`} data-brand-action="true" href="#magic-package">
            {index === 0 ? "Wchodzę w to!" : "Tak, dołączam!"}
          </a>
        </div>
      ))}
    </div>
  </div>
) : (
  <div class="mx-auto grid max-w-5xl items-center gap-8 md:grid-cols-2">
    <div>
      <h2 class="mx-auto max-w-md rounded-full border-2 border-magic-orange bg-magic-cream px-5 py-2 text-center font-display text-2xl text-magic-ink sm:text-3xl">{section.heading}</h2>
      {section.groups.map((group) => (
        <div class="mx-auto mt-5 max-w-xl">
          <p class="text-center text-sm leading-6">{group.title}</p>
          <ul class="mt-6 space-y-4 text-sm leading-6 sm:text-base">
            {group.criteria.map((criterion) => <li class="flex gap-3">
              {section.decoration ? <img alt="" aria-hidden="true" class="size-6 shrink-0" decoding="async" height={section.decoration.height} loading="lazy" src={legacyAssetPath(section.decoration.src)} width={section.decoration.width} /> : <span aria-hidden="true" class="text-magic-pink">✱</span>}
              <span>{criterion}</span>
            </li>)}
          </ul>
        </div>
      ))}
    </div>
    {section.artwork && (
      <img
        alt={section.artwork.alt}
        class="mx-auto max-h-96 w-auto max-w-full object-contain"
        decoding="async"
        height={section.artwork.height}
        loading="lazy"
        src={legacyAssetPath(section.artwork.src)}
        width={section.artwork.width}
      />
    )}
  </div>
)}
