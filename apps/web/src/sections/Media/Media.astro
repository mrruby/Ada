---
import VimeoFacade from "../../integrations/video/VimeoFacade.astro"
import type { MediaSection } from "./schema"

const { section } = Astro.props as { section: MediaSection }
---

<figure
  class="mx-auto max-w-md overflow-hidden rounded-none bg-black shadow-lg"
  data-consent-category={section.consentCategory}
  data-provider={section.provider}
  data-provider-asset-id={section.providerAssetId}
>
  <VimeoFacade assetId={section.providerAssetId} heading={section.heading} poster={section.poster} />
</figure>
