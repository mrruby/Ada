---
import type { LearningPathSection } from "./schema"

const { section } = Astro.props as { section: LearningPathSection }
const layout = section.presentation === "curriculum" ? "md:grid-cols-2 xl:grid-cols-3" : "md:grid-cols-2"
---

<div class="mx-auto max-w-6xl">
  <h2 class="font-display text-3xl leading-tight sm:text-4xl">{section.heading}</h2>
  <ol class:list={["mt-8 grid grid-cols-1 gap-5", layout]}>
    {section.stages.map((stage) => (
      <li class="surface-card rounded-3xl p-6">
        <article class="sm:flex sm:gap-4">
          <span class="surface-highlight flex size-10 shrink-0 items-center justify-center rounded-full font-display text-xl" aria-hidden="true">
            {section.stages.indexOf(stage) + 1}
          </span>
          <div>
            <h3 class="text-xl font-bold leading-snug">{stage.title}</h3>
            <p class="mt-2 leading-7">{stage.body}</p>
          </div>
        </article>
      </li>
    ))}
  </ol>
</div>
