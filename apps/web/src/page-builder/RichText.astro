---
import type { RichText } from "../page-spec/common.schema"

const { value } = Astro.props as { value: RichText }
---

{
  value.map((block) => {
    if (block.kind === "paragraph") {
      return (
        <p>
          {block.content.map((inline) => {
            const isStrong = inline.marks.includes("strong")
            const isEmphasis = inline.marks.includes("emphasis")

            if (isStrong && isEmphasis) {
              return <strong><em>{inline.text}</em></strong>
            }

            if (isStrong) {
              return <strong>{inline.text}</strong>
            }

            if (isEmphasis) {
              return <em>{inline.text}</em>
            }

            return inline.text
          })}
        </p>
      )
    }

    if (block.style === "steps") {
      return (
        <ol>
          {block.items.map((item) => <li>{item.map((inline) => inline.text)}</li>)}
        </ol>
      )
    }

    return (
      <ul>
        {block.items.map((item) => <li>{item.map((inline) => inline.text)}</li>)}
      </ul>
    )
  })
}
