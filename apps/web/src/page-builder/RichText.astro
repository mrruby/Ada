---
import type { RichText } from "../page-spec/common.schema"

const { value } = Astro.props as { value: RichText }
---

{
  value.map((block) => {
    if (block.kind === "paragraph") {
      return (
        <p class="mt-4 leading-7 first:mt-0">
          {block.content.map((inline) => {
            const isStrong = inline.marks.includes("strong")
            const isEmphasis = inline.marks.includes("emphasis")

            if (isStrong && isEmphasis) {
              return <strong><em>{inline.text}</em></strong>
            }

            if (isStrong) {
              return <strong>{inline.text}</strong>
            }

            if (isEmphasis) {
              return <em>{inline.text}</em>
            }

            return inline.text
          })}
        </p>
      )
    }

    if (block.style === "steps") {
      return (
        <ol class="mt-4 list-decimal space-y-2 pl-6 first:mt-0">
          {block.items.map((item) => (
            <li>
              {item.map((inline) => {
                const isStrong = inline.marks.includes("strong")
                const isEmphasis = inline.marks.includes("emphasis")

                if (isStrong && isEmphasis) return <strong><em>{inline.text}</em></strong>
                if (isStrong) return <strong>{inline.text}</strong>
                if (isEmphasis) return <em>{inline.text}</em>

                return inline.text
              })}
            </li>
          ))}
        </ol>
      )
    }

    return (
      <ul class:list={["mt-4 space-y-2 first:mt-0", block.style === "bullets" ? "list-disc pl-6" : "list-none"]}>
        {block.items.map((item) => (
          <li class:list={block.style === "checks" && "flex gap-2"}>
            {block.style === "checks" && <span aria-hidden="true">✓</span>}
            <span>
              {item.map((inline) => {
                const isStrong = inline.marks.includes("strong")
                const isEmphasis = inline.marks.includes("emphasis")

                if (isStrong && isEmphasis) return <strong><em>{inline.text}</em></strong>
                if (isStrong) return <strong>{inline.text}</strong>
                if (isEmphasis) return <em>{inline.text}</em>

                return inline.text
              })}
            </span>
          </li>
        ))}
      </ul>
    )
  })
}
