---
import { legacyAssetPath } from "../../lib/legacy-assets"
import { consentCopy } from "../consent/consent-copy"
import { createVimeoEmbed } from "../scripts/pilot-registry"

interface Props {
  assetId: string
  heading: string
  poster: {
    src: string
    alt: string
    width: number
    height: number
  }
}

const { assetId, heading, poster } = Astro.props
const vimeo = createVimeoEmbed(assetId)
---

<div
  data-vimeo-embed-url={vimeo.embedUrl}
  data-vimeo-facade
  data-vimeo-permissions={vimeo.permissions}
  data-vimeo-title={heading}
>
  <div class="relative" data-vimeo-mount>
    <img
      alt={poster.alt}
      class="aspect-video w-full object-cover"
      decoding="async"
      height={poster.height}
      loading="lazy"
      src={legacyAssetPath(poster.src)}
      width={poster.width}
    />
    <button
      aria-label={`${heading} — odtwórz film`}
      class="surface-strong absolute inset-0 grid place-items-center opacity-90 transition hover:opacity-100 motion-reduce:transition-none"
      data-vimeo-play
      type="button"
    >
      <span class="rounded-full border border-current px-5 py-3 font-bold">Odtwórz film</span>
    </button>
  </div>
  <p aria-live="polite" class="mt-3 text-sm" data-vimeo-notice hidden>
    {consentCopy.vimeoConsentRequired}
  </p>
  <a class="mt-3 inline-block text-sm underline decoration-2 underline-offset-4" href={vimeo.directUrl} rel="noreferrer" target="_blank">
    Obejrzyj w Vimeo
  </a>
</div>

<script src="./vimeo-facade.ts"></script>
